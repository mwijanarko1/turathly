NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk - choose ONE mode (do not mix keyless + manual):
#
# KEYLESS (recommended for new projects): Leave keys unset. Clerk auto-generates
# temporary keys on first run. A "Claim your application" prompt appears—click
# it to claim and get production keys. If you later add explicit keys, remove
# .clerk/.tmp/keyless.json to avoid redirect loops.
#
# MANUAL: Uncomment and set keys from dashboard.clerk.com → API Keys
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard
CLERK_JWT_ISSUER_DOMAIN=

# Convex
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# Google AI (Gemini)
GOOGLE_API_KEY=
